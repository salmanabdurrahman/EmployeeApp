@{
    ViewData["Title"] = "Employees";
}

<div class="mb-4">
    <h1><i class="bi bi-people-fill"></i> Employees</h1>
</div>

<!-- Kendo Grid Container -->
<div id="employeeGrid"></div>

@section Scripts {
<script>
    $(document).ready(function() {
        // Initialize Kendo Grid with full CRUD
        $("#employeeGrid").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url: "/api/EmployeeApi",
                        dataType: "json"
                    },
                    create: {
                        url: "/api/EmployeeApi",
                        type: "POST",
                        dataType: "json",
                        contentType: "application/json",
                        complete: function(e) {
                            // Refresh grid after create to show new record
                            $("#employeeGrid").data("kendoGrid").dataSource.read();
                        }
                    },
                    update: {
                        url: function(data) {
                            return "/api/EmployeeApi/" + data.id;
                        },
                        type: "PUT",
                        dataType: "json",
                        contentType: "application/json",
                        complete: function(e) {
                            // Refresh grid after update to show changes
                            $("#employeeGrid").data("kendoGrid").dataSource.read();
                        }
                    },
                    destroy: {
                        url: function(data) {
                            return "/api/EmployeeApi/" + data.id;
                        },
                        type: "DELETE",
                        dataType: "json",
                        complete: function(e) {
                            // Refresh grid after delete to show updated state
                            $("#employeeGrid").data("kendoGrid").dataSource.read();
                        }
                    },
                    parameterMap: function(data, operation) {
                        if (operation !== "read") {
                            return kendo.stringify(data);
                        }
                        return data;
                    }
                },
                schema: {
                    model: {
                        id: "id",
                        fields: {
                            id: { type: "number", editable: false },
                            name: { 
                                type: "string", 
                                validation: { required: { message: "Name is required" } } 
                            },
                            position: { 
                                type: "string", 
                                validation: { required: { message: "Position is required" } } 
                            },
                            salary: { 
                                type: "number", 
                                validation: { 
                                    required: { message: "Salary is required" },
                                    min: { message: "Salary must be greater than or equal to 0", value: 0 }
                                } 
                            }
                        }
                    }
                },
                error: function(e) {
                    var message = "Error occurred";
                    if (e.xhr && e.xhr.responseJSON) {
                        if (e.xhr.responseJSON.message) {
                            message = e.xhr.responseJSON.message;
                        }
                        if (e.xhr.responseJSON.errors && e.xhr.responseJSON.errors.length > 0) {
                            message += ":\n" + e.xhr.responseJSON.errors.join("\n");
                        }
                    }
                    alert(message);
                    // Refresh grid to show current state
                    this.read();
                },
                pageSize: 10
            },
            toolbar: [
                { 
                    name: "create", 
                    text: "Add New Employee",
                    iconClass: "k-icon k-i-plus"
                }
            ],
            editable: {
                mode: "popup",
                confirmation: "Are you sure you want to delete this employee?",
                window: {
                    title: "Employee Details",
                    width: "500px"
                }
            },
            height: 550,
            pageable: {
                pageSize: 10,
                pageSizes: [5, 10, 20, 50],
                refresh: true
            },
            sortable: true,
            filterable: true,
            columns: [
                { 
                    field: "id", 
                    title: "ID", 
                    width: "80px",
                    filterable: false
                },
                { 
                    field: "name", 
                    title: "Name",
                    width: "200px"
                },
                { 
                    field: "position", 
                    title: "Position",
                    width: "200px",
                    editor: function(container, options) {
                        $('<input name="' + options.field + '"/>')
                            .appendTo(container)
                            .kendoDropDownList({
                                dataTextField: "position",
                                dataValueField: "position",
                                dataSource: [
                                    { position: "Project Manager" },
                                    { position: "UI/UX Designer" },
                                    { position: "Backend Developer" },
                                    { position: "Marketing Manager" },
                                    { position: "Data Analyst" },
                                    { position: "HR Manager" },
                                    { position: "DevOps Engineer" },
                                    { position: "QA Engineer" },
                                    { position: "Customer Support" }
                                ],
                                optionLabel: "Select Position"
                            });
                    }
                },
                { 
                    field: "salary", 
                    title: "Salary",
                    format: "{0:c2}",
                    width: "150px",
                    editor: function(container, options) {
                        $('<input name="' + options.field + '"/>')
                            .appendTo(container)
                            .kendoNumericTextBox({
                                format: "c2",
                                decimals: 2,
                                step: 0.01,
                                min: 0
                            });
                    }
                },
                { 
                    command: [
                        { name: "edit", text: { edit: "Edit", update: "Save", cancel: "Cancel" } },
                        { name: "destroy", text: "Delete" }
                    ], 
                    title: "Actions", 
                    width: "250px" 
                }
            ]
        });
    });
</script>
}
