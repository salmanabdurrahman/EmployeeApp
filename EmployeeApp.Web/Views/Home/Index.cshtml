@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Employee Management System</h1>
    <p class="lead">Manage your employees efficiently with Kendo UI Grid powered interface.</p>
    
    <div class="row mt-5">
        <div class="col-md-6 offset-md-3">
            <div class="card">
                <div class="card-body text-center">
                    <i class="bi bi-people display-3 text-primary"></i>
                    <h5 class="card-title mt-3">Employee Management</h5>
                    <p class="card-text">View, add, edit, and delete employee records with our interactive grid interface.</p>
                    <a asp-controller="Employee" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="bi bi-arrow-right-circle"></i> Go to Employee
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
